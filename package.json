{
  "name": "audiobook-lms-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:audiobook": "turbo dev --filter=@repo/audiobook",
    "dev:lms-public": "turbo dev --filter=@repo/lms-public",
    "dev:lms-portal": "turbo dev --filter=@repo/lms-portal",
    "dev:lms-lecturer": "turbo dev --filter=@repo/lms-lecturer",
    "dev:lms-admin": "turbo dev --filter=@repo/lms-admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed": "cd packages/db && npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.3.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
